# Supabase project URL (Settings → API → Project URL)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase anonymous/public key (Settings → API → anon public)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Resend API key (https://resend.com/api-keys)
RESEND_API_KEY=re_your_api_key

# Verified sender address in Resend (e.g. onboarding@resend.dev for testing)
RESEND_FROM_EMAIL=Bookmarks App <onboarding@resend.dev>
